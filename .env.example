# Personal Dashboard configuration
# Generate VAPID keypair: `personal-dashboard generate-vapid`

# Bearer token for /api/notify and other write endpoints.
# Generate with: `python -c "import secrets; print(secrets.token_urlsafe(32))"`
NOTIFY_API_KEY=

# VAPID keys for Web Push (generate via CLI above)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Server bind address. Default loopback-only; tailscale serve proxies from the tailnet IP.
HOST=127.0.0.1
PORT=8421

# Set when running behind tailscale serve, e.g. https://yourbox.tailnet.ts.net
BASE_URL=

DEBUG=false
